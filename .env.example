# SYNQ Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE - Supabase PostgreSQL
# =============================================================================

# Connection string with pgbouncer (for application queries)
# Get from: Supabase Dashboard > Settings > Database > Connection string > URI
# Add ?pgbouncer=true at the end for connection pooling
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?pgbouncer=true

# Direct connection (for migrations - bypasses connection pooler)
# Get from: Supabase Dashboard > Settings > Database > Connection string > URI (Direct)
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# =============================================================================
# EMAIL - Resend
# =============================================================================

# Resend API key for sending transactional emails
# Get from: Resend Dashboard -> API Keys -> Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxx

# From email address for outgoing emails
# Use your verified domain or resend.dev for testing
EMAIL_FROM=bookings@yourdomain.com
