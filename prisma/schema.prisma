// Prisma schema for SYNQ booking system
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// CORE MODELS
// ============================================================================

model Service {
  id          String    @id @default(uuid())
  name        String // Primary (Japanese) e.g., "指圧"
  nameEn      String? // Fallback (English) e.g., "Shiatsu"
  description String?
  duration    Int // Minutes
  price       Int // Yen
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  bookings    Booking[]
}

model Worker {
  id                String           @id @default(uuid())
  name              String // e.g., "田中"
  nameEn            String? // e.g., "Tanaka" (English display)
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  bookings          Booking[]
  schedules         WorkerSchedule[]
  assignedCustomers Customer[]       @relation("CustomerAssignedStaff")
}

model WorkerSchedule {
  id           String    @id @default(uuid())
  workerId     String
  worker       Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)
  dayOfWeek    Int? // 0=Sunday, 6=Saturday (recurring)
  specificDate DateTime? // One-off block/availability (date only, time ignored)
  startTime    String // "09:00" format (HH:mm)
  endTime      String // "18:00" format (HH:mm)
  isAvailable  Boolean   @default(true) // false = blocked time
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([workerId, dayOfWeek, startTime, endTime])
  @@index([workerId, specificDate])
}

model Resource {
  id        String    @id @default(uuid())
  name      String // e.g., "Bed 1", "ベッド1"
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]
}

model Customer {
  id                String    @id @default(uuid())
  email             String    @unique
  phone             String?
  name              String
  locale            String    @default("ja") // "en" or "ja"
  ticketBalance     Int       @default(0) // Multi-session tickets (回数券)
  notes             String? // Admin notes
  assignedStaffId   String?
  visitCount        Int       @default(0)
  lastVisitDate     DateTime?
  outstandingAmount Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  bookings          Booking[]
  assignedStaff     Worker?   @relation("CustomerAssignedStaff", fields: [assignedStaffId], references: [id], onDelete: SetNull)

  @@index([assignedStaffId])
}

model Booking {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  startsAt  DateTime
  endsAt    DateTime
  status    String // "CONFIRMED", "CANCELLED", "NOSHOW", "PENDING"
  version   Int      @default(0) // Optimistic locking for concurrency

  workerId   String
  worker     Worker   @relation(fields: [workerId], references: [id])
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id])
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  serviceId  String
  service    Service  @relation(fields: [serviceId], references: [id])

  // Indexes for efficient availability queries (double-bottleneck logic)
  @@index([startsAt, endsAt])
  @@index([workerId, startsAt, endsAt])
  @@index([resourceId, startsAt, endsAt])
}
